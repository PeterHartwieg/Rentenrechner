+// ---------------------------------------------------------------------------
+// Issue 07: wizard inputs persist via correct state setter
+//
+// Root cause: App.tsx's onComplete callback ignored the workspace argument,
+// so portfolioState's in-memory React state stayed stale even though
+// InventoryWizard called saveWorkspace() before firing onComplete.
+//
+// Fix: portfolioState.replaceWorkspace(workspace) is now called in onComplete,
+// atomically replacing the in-memory state so the UI reflects wizard inputs
+// without a page reload.
+//
+// These tests verify:
+//  1. The workspace produced by buildWorkspaceFromDraft satisfies the
+//     Workspace type contract (replaceWorkspace can accept it unchanged).
+//  2. saveWorkspace + loadSavedWorkspace round-trip (page-reload simulation)
+//     preserves every wizard-entered field.
+//  3. After the round-trip the loaded workspace equals the saved one
+//     (migrateAndValidateState does not drop any wizard fields).
+// ---------------------------------------------------------------------------
+
+// localStorage mock (same pattern as storage.migration.test.ts — tests run in
+// a Node environment without a real browser storage API).
+function makeMemoryStorage(): Storage {
+  const store: Record<string, string> = {}
+  return {
+    get length() { return Object.keys(store).length },
+    clear() { for (const k of Object.keys(store)) delete store[k] },
+    getItem(key: string) { return key in store ? store[key] : null },
+    key(i: number) { return Object.keys(store)[i] ?? null },
+    removeItem(key: string) { delete store[key] },
+    setItem(key: string, value: string) { store[key] = value },
+  }
+}
+
+describe('Issue 07 — wizard inputs persist to portfolioState (onComplete wiring)', () => {
+  // Isolate localStorage between tests using a fresh in-memory store.
+  const originalLocalStorage = globalThis.localStorage
+  beforeEach(() => {
+    Object.defineProperty(globalThis, 'localStorage', {
+      value: makeMemoryStorage(),
+      configurable: true,
+      writable: true,
+    })
+  })
+  afterEach(() => {
+    Object.defineProperty(globalThis, 'localStorage', {
+      value: originalLocalStorage,
+      configurable: true,
+      writable: true,
+    })
+  })
+
+  it('buildWorkspaceFromDraft returns a v2 Workspace accepted by replaceWorkspace (type contract)', () => {
+    // replaceWorkspace calls setWorkspace(workspace) — the only type requirement
+    // is Workspace. Verify schemaVersion + mode + required fields are present.
+    const ws = buildWorkspaceFromDraft({
+      grvDraft: makeGrvDraft({ yearsWorked: 15, useYearsEstimate: true }),
+      bavDraft: makeBavDraft({ monthlyContribution: 250, effektivkostenPct: 0.9 }),
+      pavDraft: null, riesterDraft: null, basisrenteDraft: null,
+      avdDraft: null,
+      etfDraft: makeEtfDraft({ terPct: 0.07 }),
+      grossSalaryYear: 80_000,
+    })
+    expect(ws.schemaVersion).toBe(2)
+    expect(ws.mode).toBe('combine')
+    expect(Array.isArray(ws.whatIfs)).toBe(true)
+    expect(Array.isArray(ws.pinnedComparisonIds)).toBe(true)
+    expect(ws.baseline).toBeDefined()
+    expect(ws.baseline.assumptions).toBeDefined()
+  })
+
+  it('page-reload simulation: saveWorkspace + loadSavedWorkspace preserves ETF TER', () => {
+    // Simulate what InventoryWizard.handleComplete does before calling onComplete.
+    const ws = buildWorkspaceFromDraft({
+      grvDraft: makeGrvDraft(),
+      bavDraft: null, pavDraft: null, riesterDraft: null,
+      basisrenteDraft: null, avdDraft: null,
+      etfDraft: makeEtfDraft({ terPct: 0.07 }),
+      grossSalaryYear: 75_000,
+    })
+    saveWorkspace(ws)
+
+    // Simulate page reload — portfolioState calls loadSavedWorkspace on mount.
+    const reloaded = loadSavedWorkspace()
+    expect(reloaded).not.toBeNull()
+    const etf = reloaded!.baseline.assumptions.etf[0]
+    // 0.07% TER → annualAssetFee stored as 0.0007
+    expect(etf.annualAssetFee).toBeCloseTo(0.0007, 5)
+  })
+
+  it('page-reload simulation: saveWorkspace + loadSavedWorkspace preserves bAV monthlyGrossConversion', () => {
+    const ws = buildWorkspaceFromDraft({
+      grvDraft: makeGrvDraft(),
+      bavDraft: makeBavDraft({ monthlyContribution: 350, effektivkostenPct: 1.1 }),
+      pavDraft: null, riesterDraft: null, basisrenteDraft: null,
+      avdDraft: null, etfDraft: null,
+      grossSalaryYear: 90_000,
+    })
+    saveWorkspace(ws)
+
+    const reloaded = loadSavedWorkspace()
+    expect(reloaded).not.toBeNull()
+    const bav = reloaded!.baseline.assumptions.bav[0]
+    expect(bav.monthlyGrossConversion).toBe(350)
+    expect(bav.fees.wrapperAssetFee).toBeCloseTo(0.011, 4)
+  })
+
+  it('page-reload simulation: saveWorkspace + loadSavedWorkspace preserves GRV currentEntgeltpunkte', () => {
+    const ws = buildWorkspaceFromDraft({
+      grvDraft: makeGrvDraft({ currentEntgeltpunkte: 22.5, useYearsEstimate: false }),
+      bavDraft: null, pavDraft: null, riesterDraft: null,
+      basisrenteDraft: null, avdDraft: null, etfDraft: null,
+      grossSalaryYear: 75_000,
+    })
+    saveWorkspace(ws)
+
+    const reloaded = loadSavedWorkspace()
+    expect(reloaded).not.toBeNull()
+    expect(reloaded!.baseline.assumptions.statutoryPension.currentEntgeltpunkte).toBe(22.5)
+  })
+
+  it('loaded workspace after reload equals the saved workspace (field-for-field on critical arrays)', () => {
+    const ws = buildWorkspaceFromDraft({
+      grvDraft: makeGrvDraft({ yearsWorked: 8, useYearsEstimate: true }),
+      bavDraft: makeBavDraft({ monthlyContribution: 200 }),
+      pavDraft: null, riesterDraft: makeRiesterDraft({ currentValueEUR: 5_000 }),
+      basisrenteDraft: null, avdDraft: null,
+      etfDraft: makeEtfDraft({ terPct: 0.2 }),
+      grossSalaryYear: 60_000,
+    })
+    saveWorkspace(ws)
+
+    const reloaded = loadSavedWorkspace()
+    expect(reloaded).not.toBeNull()
+    const a = reloaded!.baseline.assumptions
+    expect(a.bav).toHaveLength(1)
+    expect(a.riester).toHaveLength(1)
+    expect(a.etf).toHaveLength(1)
+    expect(a.insurance).toHaveLength(0)
+    expect(a.basisrente).toHaveLength(0)
+    expect(a.altersvorsorgedepot).toHaveLength(0)
+    // mode must survive the round-trip
+    expect(reloaded!.mode).toBe('combine')
+  })
+})
